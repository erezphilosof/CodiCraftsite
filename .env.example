# CodiCraft Environment Variables

# SMTP Configuration for sending parents guide
# You can use Gmail (with App Password), SendGrid, Mailgun, Outlook, etc.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=585
SMTP_USER=your-email@gmail.com
# For Gmail, this must be a 16-character App Password (not your real password)
SMTP_PASS=your-app-password
SMTP_FROM="CodiCraft <your-email@gmail.com>"

# Optional: NVIDIA API Key for chatbot (if any)
# NVIDIA_API_KEY=your-nvidia-api-key
